CREATE DATABASE DBname;
USE DBname;
CREATE TABLE tableName(
-- columns, dataTypes, constrains
columName1 INT PRIMARY KEY AUTO_INCREMENT,
columName2 varchar(20) UNIQUE NOT NULL,
columName3 varchar(50) NOT NULL,
columName4 float NULL,
columName5 DATE NULL
);

--create table using another table
CREATE TABLE newTableName AS
SELECT columnName1, columnName2, ...
FROM tableName;

--add columns
ALTER TABLE tableName
ADD columnName datatype;

--drop column
ALTER TABLE tableName
DROP COLUMN columnName;

--modify column
ALTER TABLE tableName
MODIFY COLUMN columnName datatype;

--add primary key
ALTER TABLE tableName
ADD PRIMARY KEY (columnName);

--drop primary key
ALTER TABLE tableName
DROP PRIMARY KEY;

--add foreign key
ALTER TABLE tableName
ADD FOREIGN KEY (columnName) REFERENCES anotherTableName(columnName);

--limit the value
ALTER TABLE tableName
ADD CHECK (Age>=18);
