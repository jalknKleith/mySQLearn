--add primary key
ALTER TABLE tableName
ADD PRIMARY KEY (columnName);

--drop primary key
ALTER TABLE tableName
DROP PRIMARY KEY;

--add foreign key
ALTER TABLE tableName
ADD FOREIGN KEY (columnName) REFERENCES anotherTableName(columnName);

--limit the value
ALTER TABLE tableName
ADD CHECK (Age>=18);

--create a default value
ALTER TABLE tableName
ALTER columnName SET DEFAULT 'Value';

--drop a default value
ALTER TABLE tableName
ALTER columnName DROP DEFAULT;
